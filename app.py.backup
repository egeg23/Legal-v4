# ==================== DOWNLOAD ENDPOINTS ====================

@app.route(f'{API_PREFIX}/download/<int:case_id>', methods=['GET'])
@require_auth
def download_documents(case_id):
    """
    Download case documents and analysis report.
    
    Args:
        case_id: Case ID
    
    Query parameters:
        - type: Download type (documents, analysis, full_report)
    
    Returns:
        ZIP file with documents
    """
    log_request_info()
    user = request.current_user
    ip_address = get_client_ip()
    
    case = Case.query.get(case_id)
    if not case or case.user_id != user.id:
        return error_response('Case not found or access denied', 'NOT_FOUND', 404)
    
    download_type = request.args.get('type', 'full_report')
    
    # Check rate limit for subscribers
    if user.has_active_subscription():
        allowed, remaining, reset_date = check_rate_limit(user.id, ip_address)
        if not allowed:
            return jsonify({
                'success': False,
                'error': 'Rate limit exceeded',
                'message': 'You have exceeded the monthly request limit',
                'reset_date': reset_date.isoformat()
            }), 429
    
    try:
        # Generate documents
        case_data = case.to_dict(include_analysis=True)
        
        import zipfile
        import tempfile
        
        # Create temporary ZIP file
        temp_dir = tempfile.mkdtemp()
        zip_path = os.path.join(temp_dir, f'case_{case_id}_download.zip')
        
        with zipfile.ZipFile(zip_path, 'w', zipfile.ZIP_DEFLATED) as zipf:
            # Add original documents
            if download_type in ['documents', 'full_report']:
                documents = case.get_documents()
                for doc_path in documents:
                    if os.path.exists(doc_path):
                        arcname = os.path.join('documents', os.path.basename(doc_path))
                        zipf.write(doc_path, arcname)
            
            # Add analysis report
            if download_type in ['analysis', 'full_report'] and case.status == 'completed':
                report_path = generate_case_report(case_data, temp_dir)
                zipf.write(report_path, os.path.join('reports', os.path.basename(report_path)))
        
        # Record download
        download_history = DownloadHistory(
            user_id=user.id,
            case_id=case_id,
            ip_address=ip_address,
            user_agent=request.headers.get('User-Agent'),
            download_type=download_type
        )
        db.session.add(download_history)
        
        # Record IP request for subscribers
        if user.has_active_subscription():
            record_ip_request(user.id, ip_address, 'download')
        
        db.session.commit()
        
        logger.info(f"Download generated for case {case_id} by user {user.id}")
        
        return send_file(
            zip_path,
            mimetype='application/zip',
            as_attachment=True,
            download_name=f'case_{case_id}_{download_type}.zip'
        )
    
    except Exception as e:
        logger.error(f"Download failed for case {case_id}: {str(e)}")
        return error_response('Download failed', 'DOWNLOAD_ERROR', 500)


@app.route(f'{API_PREFIX}/download/report/<int:case_id>', methods=['GET'])
@require_auth
def download_report(case_id):
    """
    Download analysis report as DOCX.
    
    Args:
        case_id: Case ID
    
    Returns:
        DOCX file
    """
    log_request_info()
    user = request.current_user
    
    case = Case.query.get(case_id)
    if not case or case.user_id != user.id:
        return error_response('Case not found or access denied', 'NOT_FOUND', 404)
    
    if case.status != 'completed':
        return error_response('Analysis not completed yet', 'ANALYSIS_PENDING', 400)
    
    try:
        # Generate report
        case_data = case.to_dict(include_analysis=True)
        import tempfile
        temp_dir = tempfile.mkdtemp()
        report_path = generate_case_report(case_data, temp_dir)
        
        # Record download
        download_history = DownloadHistory(
            user_id=user.id,
            case_id=case_id,
            ip_address=get_client_ip(),
            user_agent=request.headers.get('User-Agent'),
            download_type='analysis'
        )
        db.session.add(download_history)
        db.session.commit()
        
        return send_file(
            report_path,
            mimetype='application/vnd.openxmlformats-officedocument.wordprocessingml.document',
            as_attachment=True,
            download_name=f'analysis_report_case_{case_id}.docx'
        )
    
    except Exception as e:
        logger.error(f"Report generation failed for case {case_id}: {str(e)}")
        return error_response('Report generation failed', 'GENERATION_ERROR', 500)


